# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/climate-champion

# JWT Configuration
JWT_SECRET=climate_champion_secret_key_2025_super_secure_random_string

# Client Configuration
CLIENT_URL=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads

# Admin Configuration
DEFAULT_ADMIN_EMAIL=admin@climatechampion.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# App Configuration
APP_NAME=Climate Champion Portal
APP_DESCRIPTION=Portal for Climate Champion Programme 2025 - Anant School for Climate Action
APP_VERSION=1.0.0

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=another_super_secure_session_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Types Configuration
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,jpeg,png,gif,ppt,pptx,xls,xlsx
MAX_FILES_PER_UPLOAD=5

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/climate-champion.log